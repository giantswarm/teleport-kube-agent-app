{
  extends: [
    // Base config - https://github.com/giantswarm/renovate-presets/blob/main/default.json5
    'github>giantswarm/renovate-presets:default.json5',
    'github>giantswarm/renovate-presets:disable-vendir.json5',
    'github>giantswarm/renovate-presets:disable-upstream-charts.json5',
  ],
  automerge: true,
  customManagers: [
    {
      customType: 'regex',
      managerFilePatterns: [
        '/(^|/)vendir\\.yml$/',
      ],
      matchStrings: [
        '# renovate: datasource=(?<datasource>[^\\s]+) depName=(?<depName>[^\\s]+)(?: registryUrl=(?<registryUrl>[^\\s]+))?\\n\\s+version: "(?<currentValue>[^"\\n]+)"',
      ],
      versioningTemplate: 'semver',
    },
  ],
  packageRules: [
    {
      matchFileNames: [
        'vendir.yml',
      ],
      branchPrefix: 'renovate/vendir/',
      prCreation: 'approval',
      groupName: 'teleport-upstream',
    },
  ],
}
